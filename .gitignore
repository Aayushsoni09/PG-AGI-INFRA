# Terraform downloaded providers and modules
**/.terraform/*

# State files - never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc